<style>
  #error {
    width: 600px;
    margin: 20px auto;
    padding: 20px;
    border-radius: 10px;
    border: solid 4px #666666;           /* $dark_gray の色を直接書く */
    background-color: #fafafa;           /* $very_light_gray の色を直接書く */
    text-align: center;
  }

  #error p.url {
    font-family: monospace;
  }
</style>

<div id="error">
  <h1>403 Forbidden</h1>
  <p>
    <%=
      case @exception 
      when ApplicationController::IpAddressRejected 
        "あなたのIPアドレス（#{request.ip}）からは利用できません。"
      else 
        "指定されたページを閲覧する権限がありません。"
      end       
    %>
  </p>
</div>